{
  "buildCommand": "echo 'Building static site'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/styles\\.css",
      "dest": "/styles.css",
      "headers": {
        "cache-control": "public, max-age=31536000"
      }
    },
    {
      "src": "/script\\.js",
      "dest": "/script.js",
      "headers": {
        "cache-control": "public, max-age=31536000"
      }
    },
    {
      "src": "/(?!.*\\.(?:css|js|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$)(.*)",
      "dest": "/index.html"
    }
  ]
}
